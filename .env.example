# === Supabase Edge Function (stripe-webhook) ===

# Stripe webhook signing secret - se obtiene en https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=

# URL del proyecto Supabase (se obtiene en Project Settings > API)
SUPABASE_URL=

# Service Role Key de Supabase (NO la anon key) - se obtiene en Project Settings > API
SUPABASE_SERVICE_ROLE_KEY=

# === GitHub Actions (secrets del repo) ===

# Token para deploy al repo QA (solo rama dev)
# Se configura en GitHub > Settings > Secrets > QA_DEPLOY_TOKEN
